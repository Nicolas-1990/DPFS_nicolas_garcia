<%- include("./partials/head", { title: "Inicio" }) %>
<%- include("./partials/header") %>

<main class="main">

  <!-- HERO -->
    <section class="hero">
      <h1>Accesorios y periféricos gamer</h1>
      <h3>Juegos digitales para PC y consolas</h3>
      <a href="/products" class="btn btn-primary">Explorar productos</a>
    </section>

   <!-- CATEGORÍAS -->
   <section class="categorias">
    <a href="/products?category=1" class="tab">Teclados</a>
    <a href="/products?category=2" class="tab">Mouse</a>
    <a href="/products?category=3" class="tab">Headsets</a>
    <a href="/products?category=4" class="tab">Juegos PC</a>
  </section>

<!-- DESTACADOS -->
  <h2>Productos Destacados</h2>

<div class="products-container">

  <% destacados.forEach(product => { %>

    <div class="product-card">

  <!-- BADGE -->
  <% if(product.type === "digital"){ %>
    <span class="badge digital">DIGITAL</span>
  <% } else { %>
    <span class="badge fisico">FÍSICO</span>
  <% } %>

  <!-- IMAGEN -->
  <img src="/images/products/<%= product.images[0] %>">

  <!-- NOMBRE -->
  <h3><%= product.name %></h3>

  <!-- PRECIO -->
  <div class="price-block">
    <% if(product.discount && product.discount > 0){ %>

      <p class="old-price">
        $ <%= Math.round(product.price / (1 - product.discount / 100)) %>
      </p>

      <p class="price">$ <%= product.price %></p>

      <p class="discount"><%= product.discount %>% OFF</p>

    <% } else { %>

      <p class="old-price invisible">$ 0</p>
      <p class="price">$ <%= product.price %></p>
      <p class="discount invisible">0% OFF</p>

    <% } %>

  </div>

  <% if(product.type === "digital"){ %>
    <p class="digital">Descarga inmediata</p>
  <% } else if(product.stock > 0){ %>
    <p class="stock available">En stock</p>
  <% } else { %>
    <p class="stock unavailable">Sin stock</p>
  <% } %>
    <p class="low-stock <%= (product.stock > 0 && product.stock <= 3) ? 'visible' : '' %>">¡Últimas unidades!</p>

    <a href="/products/<%= product.id %>" class="btn btn-primary">Ver detalle</a>

    </div>

  <% }) %>

</div>

</main>

<%- include("./partials/footer") %>