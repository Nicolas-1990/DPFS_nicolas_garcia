<%- include("../partials/head", { title: "Carrito" }) %>
<%- include("../partials/header") %>

<main class="main">

  <h2>Carrito de compras</h2>

  <div class="cart-container">

    <div class="cart-table">

      <div class="cart-header">
        <span>Imagen</span>
        <span>Producto</span>
        <span>Precio</span>
        <span>Cantidad</span>
        <span>Subtotal</span>
      </div>

      <% cart.forEach(item => { %>
        <div class="cart-row">

  <img src="/images/products/<%= item.image %>" class="cart-img">

  <span>
  <%= item.name %><br>

  <small class="product-type">
    <%= item.type === "digital" ? "DIGITAL" : "FÍSICO" %>
  </small>
</span>

  <span>$ <%= item.price %></span>

  <div class="quantity">

  <% if (item.type !== "digital") { %>

    <div class="qty-controls">
      <form action="/cart/increase/<%= item.id %>" method="POST">
        <button type="submit">+</button>
      </form>

      <span><%= item.quantity %></span>
      <form action="/cart/decrease/<%= item.id %>" method="POST">
        <button type="submit" <%= item.quantity <= 1 ? "disabled" : "" %>>-</button>
      </form>
    </div>

  <% } else { %>

    <span class="fixed-qty">1</span>

  <% } %>

  <form action="/cart/delete/<%= item.id %>" method="POST">
    <button type="submit" class="btn-delete">Eliminar</button>
  </form>

</div>

  <span>
    $ <%= item.price * item.quantity %>
  </span>

</div>

<% }) %>

</div>

    <div class="cart-summary">

      <div class="summary-row">
        <span>Subtotal</span>
        <span>$ <%= total %></span>
      </div>

      <div class="summary-row">
        <span>
          <% if (cart.length === 0) { %>
            Entrega
          <% } else if (onlyDigital) { %>
            Entrega
          <% } else { %>
            Envío
          <% } %>
        </span>

        <span>
          <% if (cart.length === 0) { %>
            -
          <% } else if (onlyDigital) { %>
            Inmediata
          <% } else { %>
            $ <%= shipping %>
          <% } %>
        </span>
      </div>

      <div class="summary-row total">
  <span>Total</span>
  <span>$ <%= finalTotal %></span>
</div>

<% if (cart.length === 0) { %>

  <p class="empty-cart-msg">
    Tu carrito está vacío
  </p>

<% } else { %>

  <% if (userLogged) { %>

    <a href="/cart/checkout"
       class="btn btn-primary checkout-btn">
      Finalizar compra
    </a>

  <% } else { %>

    <a href="/users/login?redirect=/cart"
       class="btn btn-primary checkout-btn">
      Iniciar sesión para comprar
    </a>

  <% } %>

<% } %>
    </div>

  </div>

</main>

  <%- include("../partials/footer") %>