<%- include("../partials/head", { title: "Editar Producto" }) %>
<%- include("../partials/header") %>

<main class="main">
  <section class="form-container">
    <h2>Editar Producto</h2>

    <form action="/products/<%= product.id %>" method="POST" class="form-group">
      <input type="hidden" name="_method" value="PUT">

  <label>Nombre</label>
  <input type="text" name="name" value="<%= oldData?.name || product.name %>">

  <label>Descripción</label>
  <textarea name="description"><%= oldData?.description || product.description %></textarea>

  <label>Precio</label>
  <input type="number" name="price" value="<%= oldData?.price || product.price %>">

  <label>Imágenes (separadas por coma)</label>
  <input type="text" name="images"
    value="<%= oldData?.images || (product.images ? JSON.parse(product.images).join(', ') : '') %>">

  <label>Tipo</label>
  <select name="type">
    <option value="fisico" <%= product.type === "fisico" ? "selected" : "" %>>Físico</option>
    <option value="digital" <%= product.type === "digital" ? "selected" : "" %>>Digital</option>
  </select>

  <label>Stock</label>
  <input type="number" name="stock" value="<%= oldData?.stock || product.stock %>">

  <label>Descuento (%)</label>
  <input type="number" name="discount" value="<%= oldData?.discount || product.discount %>">

  <label>Categoría</label>
  <input type="number" name="category_id" value="<%= oldData?.category_id || product.category_id %>">

  <label>Marca</label>
  <input type="number" name="brand_id" value="<%= oldData?.brand_id || product.brand_id %>">

  <label>Colores (separados por coma)</label>
  <input type="text" name="colors"
    value="<%= product.colors && product.colors.length > 0 ? product.colors.map(c => c.name).join(', ') : '' %>">

  <button type="submit" class="btn btn-primary">Guardar cambios</button>

</form>
  </section>
</main>

<%- include("../partials/footer") %>