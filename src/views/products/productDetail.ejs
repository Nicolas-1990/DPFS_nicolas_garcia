<%- include("../partials/head", { title: product.name }) %>
<%- include("../partials/header") %>

<main class="main">

  <div class="product-detail">

    <div class="images">

  <div class="image-zoom" id="zoomContainer">
  <img 
    src="/images/products/<%= images[0] %>" 
    class="main-image" 
    id="mainImage"
  >
</div>

<div class="thumbnails">
  <% images.slice(0, 5).forEach(img => { %>
    <img 
      src="/images/products/<%= img %>" 
      class="thumb"
    >
  <% }) %>
</div>

</div>

  <div class="info">
      <h1><%= product.name %></h1>
  <div class="price-block">
      <% if(product.discount && product.discount > 0){ %>
        <p class="old-price">$ <%= Math.round(product.price / (1 - product.discount / 100)) %></p>
        <p class="price">$ <%= product.price %></p>
      <% } else { %>
        <p class="old-price invisible">$ 0</p>
        <p class="price">$ <%= product.price %></p>
        <p class="discount invisible">0% OFF</p>
      <% } %>
  </div>

      <% if(product.discount && product.discount > 0){ %>
        <p class="discount"><%= product.discount %>% OFF</p>
      <% } %>

      <% if(product.type === "digital"){ %>
        <p class="digital">Descarga inmediata</p>
      <% } else if(product.stock > 0){ %>
        <p class="stock available">En stock</p>
      <% } else { %>
        <p class="stock unavailable">Sin stock</p>
      <% } %>
        <p class="low-stock <%= (product.stock > 0 && product.stock <= 3) ? 'visible' : '' %>">¡Últimas unidades!</p>

      <p class="<%= product.type === 'digital' ? 'digital' : 'fisico' %>">Producto: <%= product.type === "digital" ? "Digital" : "Físico" %></p>
      <p>Categoría: <%= product.category ? product.category.name : "Sin categoría" %></p>
      <p>Marca: <%= product.brand ? product.brand.name : "Sin marca" %></p>

      <% if (product.colors && product.colors.length > 0) { %>
        <p>Colores: <% product.colors.forEach(color => { %>
            <span class="color-badge"><%= color.name %></span>
          <% }) %>
        </p>
      <% } %>

      <p><%= product.description %></p>

    <div class="cart-actions-detail">

        <button 
        class="btn btn-secondary add-to-cart <%= product.stock === 0 && product.type !== 'digital' ? 'disabled' : '' %>" 
        data-id="<%= product.id %>"
        <%= product.stock === 0 && product.type !== 'digital' ? 'disabled' : '' %>
        >
        <%= product.stock === 0 && product.type !== 'digital' ? 'Producto agotado' : 'Agregar al carrito' %>
        </button>
      </div>
    </div>
  </div>

  <div class="related-products">
  <h2>Productos relacionados</h2>

  <div class="related-grid">
    <% if (!relatedProducts || relatedProducts.length === 0) { %>
      <p>No hay productos relacionados.</p>
    <% } %>

    <% relatedProducts.forEach(p => { %>

      <div class="product-card">
        <img src="/images/products/<%= p.images[0] || p.image %>">
        <h3><%= p.name %></h3>
        <p>$ <%= p.price %></p>
        <a href="/products/<%= p.id %>" class="btn btn-primary">Ver detalle</a>
      </div>
    <% }) %>
  </div>
</div>

<script src="/js/gallery.js"></script>

</main>

<%- include("../partials/footer") %>