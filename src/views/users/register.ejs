<%- include("../partials/head", { title: "Registro" }) %>
<%- include("../partials/header") %>

<main class="auth-container">
  <section class="form-container">
    <h2>Crear cuenta</h2>

    <form class="form-group" action="/users/register" method="POST" enctype="multipart/form-data">

      <label for="name">Nombre</label>
      <input type="text" name="name" id="name" value="<%= oldData?.name || '' %>" required placeholder="Ingresa tu nombre">
        <% if (errors && errors.name) { %>
          <p class="error"><%= errors.name.msg %></p>
        <% } %>

      <label for="apellido">Apellido</label>
      <input type="text" name="apellido" id="apellido" required placeholder="Ingresa tu apellido">

      <label for="email">Email</label>
      <input type="email" name="email" id="email" value="<%= oldData?.email || '' %>" required placeholder="Ingresa tu email">
        <% if (errors && errors.email) { %>
          <p class="error"><%= errors.email.msg %></p>
        <% } %>

      <label for="password">Contraseña</label>
      <input type="password" name="password" id="password" required placeholder="Ingresa tu contraseña">
        <% if (errors && errors.password) { %>
          <p class="error"><%= errors.password.msg %></p>
        <% } %>

      <label for="confirm">Confirmar contraseña</label>
      <input type="password" name="confirmPassword" required placeholder="Repetir contraseña">

      <label for="avatar">Foto de perfil</label>
      <input type="file" name="avatar" id="avatar">
        <% if (error) { %>
          <p class="error-message"><%= error %></p>
        <% } %>

    <div class="terms">
      <input type="checkbox" name="terms" id="terms"
        <%= oldData?.terms ? "checked" : "" %> required>
      <label for="terms">
        Acepto los <a href="#">términos y condiciones</a>
      </label>
    </div>

      <button type="submit" class="btn btn-primary">Registrarse</button>

      <p>
        ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
      </p>

    </form>
  </section>
</main>

<%- include("../partials/footer") %>